# ─────────────────────────────────────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────────────────────────────────────

# Canonical URL of the deployment. Local dev: http://localhost:3000
# Vercel: set to https://adsuploader.movefwd.co (Production) and the preview URL
# for Preview deployments.
NEXTAUTH_URL=http://localhost:3000

# Secret used to encrypt the JWT session (which holds the FB/Google tokens).
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Facebook / Meta (primary login + Meta Marketing API)
# From https://developers.facebook.com → your App → Settings → Basic.
# The App must have the Marketing API product enabled and be approved for the
# ads_management, ads_read and business_management permissions.
# Add OAuth redirect URI: {NEXTAUTH_URL}/api/auth/callback/facebook
# ─────────────────────────────────────────────────────────────────────────────
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Meta Graph API version to target (e.g. v21.0). Bump as Meta releases new versions.
META_GRAPH_API_VERSION=v21.0

# ─────────────────────────────────────────────────────────────────────────────
# Google (on-demand, for the Google Drive upload source)
# From https://console.cloud.google.com → APIs & Services → Credentials.
# Enable the "Google Drive API" and the "Google Picker API" for the project.
# Create an OAuth 2.0 Client ID (Web application) and add authorized redirect URI:
#   {NEXTAUTH_URL}/api/auth/callback/google
# Add {NEXTAUTH_URL} as an Authorized JavaScript origin (needed for the Picker).
# ─────────────────────────────────────────────────────────────────────────────

# Server-side OAuth client (used by NextAuth to obtain the Drive access token).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Client-side values for the Google Picker (safe to expose; NEXT_PUBLIC_*).
# NEXT_PUBLIC_GOOGLE_CLIENT_ID is the SAME OAuth client id as GOOGLE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Browser API key restricted to the Google Picker API.
# Credentials → Create credentials → API key (restrict to Picker API + your origin).
NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=

# GCP project NUMBER (not the project id). Cloud Console → Home → Project number.
# Required by the Picker (setAppId).
NEXT_PUBLIC_GOOGLE_APP_ID=
